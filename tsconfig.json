{
  "compilerOptions": {
    "declaration": true,
    "lib": ["DOM", "ES2021"],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
