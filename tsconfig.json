{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "lib": ["DOM", "ES2020"],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020"
  },
  "include": ["src/**/*.js", "src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
